mplate #prefix><el-icon class=\"el-input__icon\"><search/></el-icon></template>\r\n          </el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"图书名称\">\r\n          <el-input v-model=\"search2\" placeholder=\"请输入图书名称\" clearable>\r\n            <template #prefix><el-icon class=\"el-input__icon\"><search /></el-icon></template>\r\n          </el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"读者编号\">\r\n          <el-input v-model=\"search3\" placeholder=\"请输入读者编号\" clearable>\r\n            <template #prefix><el-icon class=\"el-input__icon\"><search /></el-icon></template>\r\n          </el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"load\" size=\"mini\">查询</el-button>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button size=\"mini\" type=\"danger\" @click=\"clear\">重置</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n\r\n    <!-- 按钮-->\r\n    <div style=\"margin: 10px 0;\" v-if=\"user.role == 1\">\r\n      <el-popconfirm title=\"确认删除?\" @confirm=\"deleteBatch\">\r\n        <template #reference>\r\n          <el-button type=\"danger\" size=\"mini\">批量删除</el-button>\r\n        </template>\r\n      </el-popconfirm>\r\n    </div>\r\n\r\n    <!-- 数据字段-->\r\n    <el-table :data=\"tableData\" stripe border @selection-change=\"handleSelectionChange\">\r\n      <el-table-column v-if=\"user.role ==1\" type=\"selection\" width=\"55\"></el-table-column>\r\n      <el-table-column prop=\"isbn\" label=\"图书编号\" sortable />\r\n      <el-table-column prop=\"bookname\" label=\"图书名称\" />\r\n      <el-table-column prop=\"readerId\" label=\"读者编号\" sortable/>\r\n      <el-table-column prop=\"lendTime\" label=\"借阅时间\" sortable/>\r\n      <el-table-column prop=\"returnTime\" label=\"归还时间\" sortable/>\r\n      <el-table-column prop=\"status\" label=\"状态\">\r\n        <template v-slot=\"scope\">\r\n          <el-tag v-if=\"scope.row.status == 0\" type=\"warning\">未归还</el-tag>\r\n          <el-tag v-else type=\"success\">已归还</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column v-if=\"user.role === 1\" label=\"操作\" width=\"230px\">\r\n        <template v-slot=\"scope\">\r\n          <el-button size=\"mini\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-popconfirm title=\"确认删除?\" @confirm=\"handleDelete(scope.row)\">\r\n            <template #reference>\r\n              <el-button type=\"danger\" size=\"mini\">删除记录</el-button>\r\n            </template>\r\n          </el-popconfirm>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 分页-->\r\n    <div style=\"margin: 10px 0\">\r\n      <el-pagination\r\n          v-model:currentPage=\"currentPage\"\r\n          :page-sizes=\"[5, 10, 20]\"\r\n          :page-size=\"pageSize\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          :total=\"total\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\"\r\n      />\r\n    </div>\r\n\r\n    <!-- 修改借阅记录对话框 -->\r\n    <el-dialog v-model=\"dialogVisible\" title=\"修改借阅记录\" width=\"30%\">\r\n      <el-form :model=\"form\" label-width=\"120px\">\r\n        <el-form-item label=\"借阅时间\">\r\n          <el-date-picker\r\n              v-model=\"form.lendTime\"\r\n              type=\"datetime\"\r\n              value-format=\"YYYY-MM-DD HH:mm:ss\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"归还时间\">\r\n          <el-date-picker\r\n              v-model=\"form.returnTime\"\r\n              type=\"datetime\"\r\n              value-format=\"YYYY-MM-DD HH:mm:ss\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"是否归还\" prop=\"status\">\r\n          <el-radio v-model=\"form.status\" label=\"0\">未归还</el-radio>\r\n          <el-radio v-model=\"form.status\" label=\"1\">已归还</el-radio>\r\n        </el-form-item>\r\n      </el-form>\r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\r\n          <el-button type=\"primary\" @click=\"save\">确定</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"../utils/request\";\r\nimport { ElMessage } from \"element-plus\";\r\nimport router from \"@/router\";\r\n\r\nexport default {\r\n  created() {\r\n    let userJson = sessionStorage.getItem(\"user\")\r\n    if (!userJson) {\r\n      router.push(\"/login\")\r\n    }\r\n    let userStr = sessionStorage.getItem(\"user\") || \"{}\"\r\n    this.user = JSON.parse(userStr)\r\n    this.load()\r\n  },\r\n  name: 'LendRecord',\r\n  data() {\r\n    return {\r\n      form: {},\r\n      search1: '',\r\n      search2: '',\r\n      search3: '',\r\n      total: 0,\r\n      currentPage: 1,\r\n      pageSize: 10,\r\n      tableData: [],\r\n      user: {},\r\n      forms: [],\r\n      dialogVisible: false\r\n    }\r\n  },\r\n  methods: {\r\n    handleSelectionChange(val) {\r\n      this.forms = val\r\n    },\r\n    async deleteBatch() {\r\n      if (!this.forms.length) {\r\n        ElMessage.warning(\"请选择数据！\")\r\n        return\r\n      }\r\n      try {\r\n        const res = await request.post(\"http://localhost:8083/LendRecord/deleteRecords\", this.forms)\r\n        if (res.code === '0') {\r\n          ElMessage.success(\"批量删除成功\")\r\n          this.load()\r\n        } else {\r\n          ElMessage.error(res.msg)\r\n        }\r\n      } catch (error) {\r\n        ElMessage.error(\"操作失败\")\r\n      }\r\n    },\r\n    async load() {\r\n      try {\r\n        const res = await request.get(\"http://localhost:8083/LendRecord\", {\r\n          params: {\r\n            pageNum: this.currentPage,\r\n            pageSize: this.pageSize,\r\n            search1: this.search1,\r\n            search2: this.search2,\r\n            search3: this.search3\r\n          }\r\n        })\r\n        if (res.code == 0) {\r\n          this.tableData = res.data.records\r\n          this.total = res.data.total\r\n        }\r\n      } catch (error) {\r\n        console.error(\"加载失败\", error)\r\n      }\r\n    },\r\n    async save() {\r\n      try {\r\n        let res\r\n        // 判断是否有 id（编辑操作）\r\n        if (this.form.id) {\r\n          // 更新操作\r\n          res = await request.put(\"http://localhost:8083/LendRecord/\" + this.form.isbn, this.form)\r\n          if (res.code == 0) {\r\n            ElMessage.success('更新成功')\r\n          } else {\r\n            ElMessage.error(res.msg)\r\n            return\r\n          }\r\n        } else {\r\n          // 新增操作\r\n          res = await request.post(\"http://localhost:8083/LendRecord\", this.form)\r\n          if (res.code == 0) {\r\n            ElMessage.success('新增成功')\r\n          } else {\r\n            ElMessage.error(res.msg)\r\n            return\r\n          }\r\n        }\r\n        this.dialogVisible = false\r\n        this.load()\r\n      } catch (error) {\r\n        console.error(\"保存失败:\", error)\r\n        ElMessage.error(\"操作失败\")\r\n      }\r\n    },\r\n    clear() {\r\n      this.search1 = \"\"\r\n      this.search2 = \"\"\r\n      this.search3 = \"\"\r\n      this.load()\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogVisible = true\r\n    },\r\n    handleSizeChange(pageSize) {\r\n      this.pageSize = pageSize\r\n      this.load()\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.currentPage = pageNum\r\n      this.load()\r\n    },\r\n    async handleDelete(row) {\r\n      try {\r\n        const res = await request.post(\"http://localhost:8083/LendRecord/deleteRecord\", row)\r\n        if (res.code == 0) {\r\n          ElMessage.success(\"删除成功\")\r\n          this.load()\r\n        } else {\r\n          ElMessage.error(res.msg)\r\n        }\r\n      } catch (error) {\r\n        ElMessage.error(\"操作失败\")\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AA+GA,OAAOA,OAAM,MAAO,kBAAkB;AACtC,SAASC,SAAQ,QAAS,cAAc;AACxC,OAAOC,MAAK,MAAO,UAAU;AAE7B,eAAe;EACbC,OAAOA,CAAA,EAAG;IACR,IAAIC,QAAO,GAAIC,cAAc,CAACC,OAAO,CAAC,MAAM;IAC5C,IAAI,CAACF,QAAQ,EAAE;MACbF,MAAM,CAACK,IAAI,CAAC,QAAQ;IACtB;IACA,IAAIC,OAAM,GAAIH,cAAc,CAACC,OAAO,CAAC,MAAM,KAAK,IAAG;IACnD,IAAI,CAACG,IAAG,GAAIC,IAAI,CAACC,KAAK,CAACH,OAAO;IAC9B,IAAI,CAACI,IAAI,CAAC;EACZ,CAAC;EACDC,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE,CAAC,CAAC;MACRC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE,CAAC;MACRC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAE,EAAE;MACbb,IAAI,EAAE,CAAC,CAAC;MACRc,KAAK,EAAE,EAAE;MACTC,aAAa,EAAE;IACjB;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,qBAAqBA,CAACC,GAAG,EAAE;MACzB,IAAI,CAACJ,KAAI,GAAII,GAAE;IACjB,CAAC;IACD,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI,CAAC,IAAI,CAACL,KAAK,CAACM,MAAM,EAAE;QACtB5B,SAAS,CAAC6B,OAAO,CAAC,QAAQ;QAC1B;MACF;MACA,IAAI;QACF,MAAMC,GAAE,GAAI,MAAM/B,OAAO,CAACgC,IAAI,CAAC,gDAAgD,EAAE,IAAI,CAACT,KAAK;QAC3F,IAAIQ,GAAG,CAACE,IAAG,KAAM,GAAG,EAAE;UACpBhC,SAAS,CAACiC,OAAO,CAAC,QAAQ;UAC1B,IAAI,CAACtB,IAAI,CAAC;QACZ,OAAO;UACLX,SAAS,CAACkC,KAAK,CAACJ,GAAG,CAACK,GAAG;QACzB;MACF,EAAE,OAAOD,KAAK,EAAE;QACdlC,SAAS,CAACkC,KAAK,CAAC,MAAM;MACxB;IACF,CAAC;IACD,MAAMvB,IAAIA,CAAA,EAAG;MACX,IAAI;QACF,MAAMmB,GAAE,GAAI,MAAM/B,OAAO,CAACqC,GAAG,CAAC,kCAAkC,EAAE;UAChEC,MAAM,EAAE;YACNC,OAAO,EAAE,IAAI,CAACnB,WAAW;YACzBC,QAAQ,EAAE,IAAI,CAACA,QAAQ;YACvBL,OAAO,EAAE,IAAI,CAACA,OAAO;YACrBC,OAAO,EAAE,IAAI,CAACA,OAAO;YACrBC,OAAO,EAAE,IAAI,CAACA;UAChB;QACF,CAAC;QACD,IAAIa,GAAG,CAACE,IAAG,IAAK,CAAC,EAAE;UACjB,IAAI,CAACX,SAAQ,GAAIS,GAAG,CAACjB,IAAI,CAAC0B,OAAM;UAChC,IAAI,CAACrB,KAAI,GAAIY,GAAG,CAACjB,IAAI,CAACK,KAAI;QAC5B;MACF,EAAE,OAAOgB,KAAK,EAAE;QACdM,OAAO,CAACN,KAAK,CAAC,MAAM,EAAEA,KAAK;MAC7B;IACF,CAAC;IACD,MAAMO,IAAIA,CAAA,EAAG;MACX,IAAI;QACF,IAAIX,GAAE;QACN;QACA,IAAI,IAAI,CAAChB,IAAI,CAAC4B,EAAE,EAAE;UAChB;UACAZ,GAAE,GAAI,MAAM/B,OAAO,CAAC4C,GAAG,C