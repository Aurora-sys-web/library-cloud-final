lass=\"el-input__icon\"><User /></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"password\">\r\n        <el-input v-model=\"form.password\" placeholder=\"密码\" clearable show-password>\r\n          <template #prefix>\r\n            <el-icon class=\"el-input__icon\"><Lock /></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <div style=\"display: flex\">\r\n          <el-input  v-model=\"form.validCode\" style=\"width: 45%;\" placeholder=\"请输入验证码\"></el-input>\r\n          <ValidCode @input=\"createValidCode\" style=\"width: 50%\"/>\r\n        </div>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <el-button type=\"primary\"  style=\" width: 100%;height: 130%;font-size: 16px\" @click=\"login\">登 录</el-button>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <el-button type=\"text\" style=\"font-size: 16px;width: 20%; color: #ee7463\" @click=\"$router.push('/forget')\">忘记密码?</el-button>\r\n        <el-button type=\"text\" style=\"font-size: 16px;margin-left: 139px\" @click=\"$router.push('/register')\">没有账号?前往注册</el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n</div>\r\n\r\n</template>\r\n\r\n<script>\r\nimport request from \"../utils/request\";\r\nimport {ElMessage} from \"element-plus\";\r\nimport ValidCode from \"../components/Validate\";\r\n\r\nexport default {\r\n  name: \"Login\",\r\n  components:{\r\n    ValidCode\r\n  },\r\n  data() {\r\n    return {\r\n      validCode: '',//通过valicode获取的验证码\r\n      form: {},\r\n      rules: {\r\n        username: [\r\n          {\r\n            required: true,\r\n            message: '请输入用户名',\r\n            trigger: 'blur',\r\n          }\r\n        ],\r\n        password: [\r\n          {\r\n            required: true,\r\n            message: '请输入密码',\r\n            trigger: 'blur',\r\n          }\r\n        ]\r\n\r\n      }\r\n\r\n    }\r\n  },\r\n  methods: {\r\n    createValidCode(data){\r\n      this.validCode = data\r\n    },\r\n    login(){\r\n      this.$refs['form'].validate((valid) => {\r\n        if (valid) {\r\n          if (!this.form.validCode) {\r\n            ElMessage.error(\"请填写验证码\")\r\n            return\r\n          }\r\n          if(this.form.validCode.toLowerCase() !== this.validCode.toLowerCase()) {\r\n            ElMessage.error(\"验证码错误\")\r\n            return\r\n          }\r\n\r\n          request.post(\"user/login\", this.form).then(res => {\r\n            if (res.code == 0) {\r\n              ElMessage.success(\"登录成功\")\r\n              sessionStorage.setItem(\"user\",JSON.stringify(res.data))//缓存用户信息\r\n              this.$router.push(\"/dashboard\")\r\n            } else {\r\n              ElMessage.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n<style scoped>\r\n.login-container {\r\n  position: fixed;\r\n  width: 100%;\r\n  height: 100vh;\r\n  background: url('../img/bg2.svg');\r\n  background-size: contain;\r\n  overflow: hidden;\r\n}\r\n.login-page {\r\n  border-radius: 5px;\r\n  margin: 300px auto;\r\n  width: 420px;\r\n  padding: 35px 35px 15px;\r\n  background: #fff;\r\n  border: 1px solid #eaeaea;\r\n  box-shadow: 0 0 25px #cac6c6;\r\n}\r\n/deep/ .el-input__inner{\r\n  height: 40px;\r\n}\r\n</style>\r\n"],"mappings":";;AAqCA,OAAOA,OAAM,MAAO,kBAAkB;AACtC,SAAQC,SAAS,QAAO,cAAc;AACtC,OAAOC,SAAQ,MAAO,wBAAwB;AAE9C,eAAe;EACbC,IAAI,EAAE,OAAO;EACbC,UAAU,EAAC;IACTF;EACF,CAAC;EACDG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,EAAE;MAAC;MACdC,IAAI,EAAE,CAAC,CAAC;MACRC,KAAK,EAAE;QACLC,QAAQ,EAAE,CACR;UACEC,QAAQ,EAAE,IAAI;UACdC,OAAO,EAAE,QAAQ;UACjBC,OAAO,EAAE;QACX,EACD;QACDC,QAAQ,EAAE,CACR;UACEH,QAAQ,EAAE,IAAI;UACdC,OAAO,EAAE,OAAO;UAChBC,OAAO,EAAE;QACX;MAGJ;IAEF;EACF,CAAC;EACDE,OAAO,EAAE;IACPC,eAAeA,CAACV,IAAI,EAAC;MACnB,IAAI,CAACC,SAAQ,GAAID,IAAG;IACtB,CAAC;IACDW,KAAKA,CAAA,EAAE;MACL,IAAI,CAACC,KAAK,CAAC,MAAM,CAAC,CAACC,QAAQ,CAA