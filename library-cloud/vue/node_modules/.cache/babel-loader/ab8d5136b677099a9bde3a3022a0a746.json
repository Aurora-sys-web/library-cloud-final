{"remainingRequest":"D:\\books\\Library-Management-System\\vue\\node_modules\\babel-loader\\lib\\index.js!D:\\books\\Library-Management-System\\vue\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\books\\Library-Management-System\\vue\\node_modules\\vue-loader-v16\\dist\\index.js??ref--1-1!D:\\books\\Library-Management-System\\vue\\src\\views\\Forget.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\books\\Library-Management-System\\vue\\src\\views\\Forget.vue","mtime":1781075927980},{"path":"D:\\books\\Library-Management-System\\vue\\babel.config.js","mtime":1781075927895},{"path":"D:\\books\\Library-Management-System\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1781088196554},{"path":"D:\\books\\Library-Management-System\\vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1781088201353},{"path":"D:\\books\\Library-Management-System\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1781088196554},{"path":"D:\\books\\Library-Management-System\\vue\\node_modules\\vue-loader-v16\\dist\\index.js","mtime":1781088201252}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["request","ElMessage","name","data","buttonName","isDisabled","time","form","rules","username","required","message","trigger","min","max","password","confirm","methods","getcode","error","get","params","then","res","code","success","me","interval","window","setInterval","clearInterval","msg","register","$refs","validate","valid","post","$router","push"],"sources":["D:\\books\\Library-Management-System\\vue\\src\\views\\Forget.vue"],"sourcesContent":["<template>\r\n  <div  class=\"login-container\"  >\r\n    <el-form ref=\"form\" :model=\"form\"    :rules=\"rules\" class=\"login-page\">\r\n      <h2 class=\"title\" style=\"margin-bottom: 20px\">密码重置</h2>\r\n      <el-form-item prop=\"username\" >\r\n        <el-input v-model=\"form.username\" placeholder=\"请输入您的用户名\" clearable >\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"password\">\r\n        <el-input v-model=\"form.password\"  placeholder=\"请输入新密码\" clearable show-password>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"confirm\">\r\n        <el-input v-model=\"form.confirm\" placeholder=\"请再次确认密码\" clearable show-password>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item>\r\n          <el-input  v-model=\"form.code\" style=\"width: 45%;\" placeholder=\"请输入验证码\"></el-input>\r\n          <el-button type=\"success\" plain  style=\"margin-left: 10px\" @click=\"getcode\" :disabled=\"isDisabled\">{{buttonName}}</el-button>\r\n      </el-form-item>\r\n      <el-form-item >\r\n        <el-button type=\"primary\" style=\" width: 100%;font-size: 18px\" @click=\"register\">密码重置</el-button>\r\n      </el-form-item>\r\n      <el-form-item><el-button type=\"text\" style=\"font-size: 16px\"  @click=\"$router.push('/login')\">前往登录>> </el-button></el-form-item>\r\n    </el-form>\r\n  </div>\r\n\r\n</template>\r\n\r\n<script>\r\nimport request from \"../utils/request\";\r\nimport {ElMessage} from \"element-plus\";\r\nexport default {\r\n  name: \"Forget\",\r\n  data(){\r\n    return{\r\n      buttonName: \"获取短信验证码\",\r\n      isDisabled: false,\r\n      time: 60,\r\n      form:{},\r\n      rules: {\r\n        username: [\r\n          {\r\n            required: true,\r\n            message: '请输入用户名',\r\n            trigger: 'blur',\r\n          },\r\n          {\r\n            min: 2,\r\n            max: 13,\r\n            message: '长度要求为2到13位',\r\n            trigger: 'blur',\r\n          },\r\n        ],\r\n        password: [\r\n          {\r\n            required: true,\r\n            message: '请输入密码',\r\n            trigger: 'blur',\r\n          }\r\n        ],\r\n        confirm:[\r\n          {\r\n            required:true,\r\n            message:\"请确认密码\",\r\n            trigger:\"blur\"\r\n          }\r\n        ],\r\n      }\r\n    }\r\n  },\r\n\r\n  methods:{\r\n    getcode(){\r\n      if (!this.form.username) {\r\n        ElMessage.error(\"请填写用户名\")\r\n        return\r\n      }\r\n      if (!this.form.password) {\r\n        ElMessage.error(\"请填写新密码\")\r\n        return\r\n      }\r\n      if(this.form.password != this.form.confirm)\r\n      {\r\n        ElMessage.error(\"两次密码输入不一致\")\r\n        return\r\n      }\r\n      request.get(\"forget/getcode\",{\r\n        params:{\r\n          username:this.form.username\r\n        }\r\n      }).then(res=>{\r\n        if (res.code == 0) {\r\n          ElMessage.success(\"验证码发送成功\")\r\n          let me = this;\r\n          me.isDisabled = true;\r\n          let interval = window.setInterval(function() {\r\n            me.buttonName = '（' + me.time + '秒）后重新发送';\r\n            --me.time;\r\n            if(me.time < 0) {\r\n              me.buttonName = \"重新发送\";\r\n              me.time = 60;\r\n              me.isDisabled = false;\r\n              window.clearInterval(interval);\r\n            }\r\n          }, 1000);\r\n        } else {\r\n          ElMessage.error(res.msg)\r\n        }\r\n      })\r\n    },\r\n    register(){\r\n      this.$refs['form'].validate((valid) => {\r\n        if (valid) {\r\n          if (!this.form.code) {\r\n            ElMessage.error(\"请填写验证码\")\r\n            return\r\n          }\r\n          if (!this.form.password) {\r\n            ElMessage.error(\"请填写新密码\")\r\n            return\r\n          }\r\n          if(this.form.password != this.form.confirm)\r\n          {\r\n            ElMessage.error(\"两次密码输入不一致\")\r\n            return\r\n          }\r\n          request.post(\"forget/register\",this.form).then(res=>{\r\n            if(res.code == 0)\r\n            {\r\n              ElMessage.success(\"密码修改成功\")\r\n              this.$router.push(\"/login\")\r\n            }\r\n            else {ElMessage.error(res.msg)}\r\n          })\r\n        }\r\n      })\r\n\r\n    }\r\n  }\r\n\r\n}\r\n\r\n</script>\r\n\r\n<style scoped>\r\n.login-container {\r\n  position: fixed;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: url('../img/bg2.svg');\r\n  background-size: contain;\r\n}\r\n.login-page {\r\n  border-radius: 5px;\r\n  margin: 180px auto;\r\n  width: 350px;\r\n  padding: 35px 35px 15px;\r\n  background: #fff;\r\n  border: 1px solid #eaeaea;\r\n  box-shadow: 0 0 25px #cac6c6;\r\n}\r\n</style>"],"mappings":";AA8BA,OAAOA,OAAM,MAAO,kBAAkB;AACtC,SAAQC,SAAS,QAAO,cAAc;AACtC,eAAe;EACbC,IAAI,EAAE,QAAQ;EACdC,IAAIA,CAAA,EAAE;IACJ,OAAM;MACJC,UAAU,EAAE,SAAS;MACrBC,UAAU,EAAE,KAAK;MACjBC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAC,CAAC,CAAC;MACPC,KAAK,EAAE;QACLC,QAAQ,EAAE,CACR;UACEC,QAAQ,EAAE,IAAI;UACdC,OAAO,EAAE,QAAQ;UACjBC,OAAO,EAAE;QACX,CAAC,EACD;UACEC,GAAG,EAAE,CAAC;UACNC,GAAG,EAAE,EAAE;UACPH,OAAO,EAAE,YAAY;UACrBC,OAAO,EAAE;QACX,CAAC,CACF;QACDG,QAAQ,EAAE,CACR;UACEL,QAAQ,EAAE,IAAI;UACdC,OAAO,EAAE,OAAO;UAChBC,OAAO,EAAE;QACX,EACD;QACDI,OAAO,EAAC,CACN;UACEN,QAAQ,EAAC,IAAI;UACbC,OAAO,EAAC,OAAO;UACfC,OAAO,EAAC;QACV;MAEJ;IACF;EACF,CAAC;EAEDK,OAAO,EAAC;IACNC,OAAOA,CAAA,EAAE;MACP,IAAI,CAAC,IAAI,CAACX,IAAI,CAACE,QAAQ,EAAE;QACvBR,SAAS,CAACkB,KAAK,CAAC,QAAQ;QACxB;MACF;MACA,IAAI,CAAC,IAAI,CAACZ,IAAI,CAACQ,QAAQ,EAAE;QACvBd,SAAS,CAACkB,KAAK,CAAC,QAAQ;QACxB;MACF;MACA,IAAG,IAAI,CAACZ,IAAI,CAACQ,QAAO,IAAK,IAAI,CAACR,IAAI,CAACS,OAAO,EAC1C;QACEf,SAAS,CAACkB,KAAK,CAAC,WAAW;QAC3B;MACF;MACAnB,OAAO,CAACoB,GAAG,CAAC,gBAAgB,EAAC;QAC3BC,MAAM,EAAC;UACLZ,QAAQ,EAAC,IAAI,CAACF,IAAI,CAACE;QACrB;MACF,CAAC,CAAC,CAACa,IAAI,CAACC,GAAG,IAAE;QACX,IAAIA,GAAG,CAACC,IAAG,IAAK,CAAC,EAAE;UACjBvB,SAAS,CAACwB,OAAO,CAAC,SAAS;UAC3B,IAAIC,EAAC,GAAI,IAAI;UACbA,EAAE,CAACrB,UAAS,GAAI,IAAI;UACpB,IAAIsB,QAAO,GAAIC,MAAM,CAACC,WAAW,CAAC,YAAW;YAC3CH,EAAE,CAACtB,UAAS,GAAI,GAAE,GAAIsB,EAAE,CAACpB,IAAG,GAAI,SAAS;YACzC,EAAEoB,EAAE,CAACpB,IAAI;YACT,IAAGoB,EAAE,CAACpB,IAAG,GAAI,CAAC,EAAE;cACdoB,EAAE,CAACtB,UAAS,GAAI,MAAM;cACtBsB,EAAE,CAACpB,IAAG,GAAI,EAAE;cACZoB,EAAE,CAACrB,UAAS,GAAI,KAAK;cACrBuB,MAAM,CAACE,aAAa,CAACH,QAAQ,CAAC;YAChC;UACF,CAAC,EAAE,IAAI,CAAC;QACV,OAAO;UACL1B,SA