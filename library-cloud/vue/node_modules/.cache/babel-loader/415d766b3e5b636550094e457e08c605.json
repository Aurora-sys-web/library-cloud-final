ogin-container\"  >\r\n    <el-form ref=\"form\" :model=\"form\"    :rules=\"rules\" class=\"login-page\">\r\n      <h2 class=\"title\" style=\"margin-bottom: 20px\">用户注册</h2>\r\n      <el-form-item prop=\"username\" >\r\n        <el-input v-model=\"form.username\" placeholder=\"请输入用户名\" clearable >\r\n          <template #prefix>\r\n            <el-icon class=\"el-input__icon\"><User/></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"password\">\r\n        <el-input v-model=\"form.password\"  placeholder=\"请输入密码\" clearable show-password>\r\n          <template #prefix>\r\n            <el-icon class=\"el-input__icon\"><Lock /></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"confirm\">\r\n        <el-input v-model=\"form.confirm\" placeholder=\"请再次确认密码\" clearable show-password>\r\n          <template #prefix>\r\n            <el-icon class=\"el-input__icon\"><Lock /></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item prop=\"role\">\r\n        <el-radio v-model=\"form.role\" label=\"2\">读者</el-radio>\r\n        <el-radio v-model=\"form.role\" label=\"1\">管理员</el-radio>\r\n      </el-form-item>\r\n      <el-form-item prop=\"authorize\" v-if=\"form.role==1\">\r\n        <el-input v-model=\"form.authorize\" placeholder=\"请输入管理员注册码\" clearable show-password>\r\n          <template #prefix>\r\n            <el-icon class=\"el-input__icon\"><Lock /></el-icon>\r\n          </template>\r\n        </el-input>\r\n      </el-form-item>\r\n      <el-form-item>\r\n        <div style=\"display: flex\">\r\n          <el-input  v-model=\"form.validCode\" style=\"width: 45%;\" placeholder=\"请输入验证码\"></el-input>\r\n          <ValidCode @input=\"createValidCode\" style=\"width: 50%\"/>\r\n        </div>\r\n      </el-form-item>\r\n      <el-form-item >\r\n        <el-button type=\"primary\" style=\" width: 100%;font-size: 20px\"  @click=\"register\">注 册</el-button>\r\n      </el-form-item>\r\n      <el-form-item><el-button type=\"text\" style=\"font-size: 16px\" @click=\"$router.push('/login')\">前往登录>> </el-button></el-form-item>\r\n    </el-form>\r\n</div>\r\n\r\n</template>\r\n\r\n<script>\r\nimport request from \"../utils/request\";\r\nimport {ElMessage} from \"element-plus\";\r\nimport ValidCode from \"../components/Validate\";\r\nexport default {\r\n  name: \"Login\",\r\n  components:{\r\n    ValidCode\r\n  },\r\n  data(){\r\n    return{\r\n      form:{},\r\n      validCode: '',\r\n      rules: {\r\n        username: [\r\n          {\r\n            required: true,\r\n            message: '请输入用户名',\r\n            trigger: 'blur',\r\n          },\r\n          {\r\n            min: 2,\r\n            max: 13,\r\n            message: '长度要求为2到13位',\r\n            trigger: 'blur',\r\n          },\r\n        ],\r\n        password: [\r\n          {\r\n            required: true,\r\n            message: '请输入密码',\r\n            trigger: 'blur',\r\n          }\r\n        ],\r\n      confirm:[\r\n        {\r\n          required:true,\r\n          message:\"请确认密码\",\r\n          trigger:\"blur\"\r\n        }\r\n      ],\r\n        authorize:[\r\n          {\r\n            required:true,\r\n            message:\"请输入注册码\",\r\n            trigger:\"blur\"\r\n          }\r\n        ],\r\n      }\r\n    }\r\n    },\r\n\r\n  methods:{\r\n    createValidCode(data){\r\n      this.validCode =data\r\n    },\r\n    register(){\r\n      this.$refs['form'].validate((valid) => {\r\n        if (valid) {\r\n          if (!this.form.validCode) {\r\n            ElMessage.error(\"请填写验证码\")\r\n            return\r\n          }\r\n          if(this.form.validCode.toLowerCase() !== this.validCode.toLowerCase()) {\r\n            ElMessage.error(\"验证码错误\")\r\n            return\r\n          }\r\n          if(this.form.password != this.form.confirm)\r\n          {\r\n            ElMessage.error(\"两次密码输入不一致\")\r\n            return\r\n          }\r\n          if(this.form.role == 1 && this.form.authorize != \"2236\")\r\n          {\r\n            ElMessage.error(\"请输入正确的注册码\")\r\n            return\r\n          }\r\n          request.post(\"user/register\",this.form).then(res=>{\r\n            if(res.code == 0)\r\n            {\r\n              ElMessage.success(\"注册成功\")\r\n              this.$router.push(\"/login\")\r\n            }\r\n            else {ElMessage.error(res.msg)}\r\n          })\r\n        }\r\n      })\r\n\r\n    }\r\n  }\r\n\r\n  }\r\n\r\n</script>\r\n\r\n<style scoped>\r\n.login-container {\r\n  position: fixed;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: url('../img/bg2.svg');\r\n  background-size: contain;\r\n}\r\n.login-page {\r\n  border-radius: 5px;\r\n  margin: 180px auto;\r\n  width: 350px;\r\n  padding: 35px 35px 15px;\r\n  background: #fff;\r\n  border: 1px solid #eaeaea;\r\n  box-shadow: 0 0 25px #cac6c6;\r\n}\r\n</style>"],"mappings":";;;EACMA,KAAK,EAAC;AAAiB;;EAoChBC,KAAqB,EAArB;IAAA;EAAA;AAAqB;;;;;;;;;;;uBApClCC,mBAAA,CA8CM,OA9CNC,UA8CM,GA7CFC,YAAA,CA4CUC,kBAAA;IA5CDC,GAAG,EAAC,MAAM;IAAEC,KAAK,EAAEC,KAAA,CAAAC,IAAI;IAAMC,KAAK,EAAEF,KAAA,CAAAE,KAAK;IAAEV,KAAK,EAAC;;sBACxD,MAAuD,C,4BAAvDW,mBAAA,CAAuD;MAAnDX,KAAK,EAAC,OAAO;MAACC,KAA2B,EAA3B;QAAA;MAAA;OAA4B,MAAI,qBAClDG,YAAA,CAMeQ,uBAAA;MANDC,IAAI,EAAC;IAAU;wBAC3B,MAIW,CAJXT,YAAA,CAIWU,mBAAA;oBAJQN,KAAA,CAAAC,IAAI,CAACM,QAAQ;mEAAbP,KAAA,CAAAC,IAAI,CAACM,QAAQ,GAAAC,MAAA;QAAEC,WAAW,EAAC,QAAQ;QAACC,SAAS,EAAT;;QAC1CC,MAAM,EAAAC,QAAA,CACf,MAAiD,CAAjDhB,YAAA,CAAiDiB,kBAAA;UAAxCrB,KAAK,EAAC;QAAgB;4BAAC,MAAO,CAAPI,YAAA,CAAOkB,eAAA,E;;;;;;QAI7ClB,YAAA,CAMeQ,uBAAA;MANDC,IAAI,EAAC;IAAU;wBAC3B,MAIW,CAJXT,YAAA,CAIWU,mBAAA;oBAJQN,KAAA,CAAAC,IAAI,CAACc,QAAQ;mEAAbf,KAAA,CAAAC,IAAI,CAACc,QAAQ,GAAAP,MAAA;QAAGC,WAAW,EAAC,OAAO;QAACC,SAAS,EAAT,EAAS;QAAC,eAAa,EAAb;;QACpDC,MAAM,EAAAC,QAAA,CACf,MAAkD,CAAlDhB,YAAA,CAAkDiB,kBAAA;UAAzCrB,KAAK,EAAC;QAAgB;4BAAC,MAAQ,CAARI,YAAA,CAAQoB,eAAA,E;;;;;;QAI9