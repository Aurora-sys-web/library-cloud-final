rgin-top: 40px\" >\r\n        <h2 style=\"padding: 30px\">个人信息</h2>\r\n      <el-form :model=\"form\" ref=\"form\" label-width=\"80px\">\r\n        <el-form-item label=\"用户名\">\r\n          <el-input style=\"width: 80%\" v-model=\"form.username\" disabled></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"姓名\">\r\n          <el-input style=\"width: 80%\" v-model=\"form.nickName\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"权限\">\r\n            <span v-if=\"form.role==1\" style=\"margin:5px\">管理员</span>\r\n            <span v-if=\"form.role==2\" style=\"margin:5px\">读者</span>\r\n        </el-form-item>\r\n        <el-form-item label=\"电话号码\">\r\n          <el-input style=\"width: 40%\" v-model=\"form.phone\"></el-input>\r\n          <el-tag type=\"danger\" style=\"margin-left: 20px\">如果修改了手机号请先重新登录再使用</el-tag>\r\n        </el-form-item>\r\n        <el-form-item label=\"性别\">\r\n          <div>\r\n            <el-radio v-model=\"form.sex\" label=\"男\">男</el-radio>\r\n            <el-radio v-model=\"form.sex\" label=\"女\">女</el-radio>\r\n          </div>\r\n        </el-form-item>\r\n        <el-form-item label=\"地址\">\r\n          <el-input type=\"textarea\" style=\"width: 80%\" v-model=\"form.address\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div style=\"text-align: center\">\r\n        <el-button type=\"primary\" @click=\"update\">保存</el-button>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport {ElMessage} from \"element-plus\";\r\nimport router from \"@/router\";\r\n\r\nexport default {\r\n  name: \"Person\",\r\n  data() {\r\n    return {\r\n      form: {}\r\n    }\r\n  },\r\n  created() {\r\n    let userJson = sessionStorage.getItem(\"user\")\r\n    if(!userJson)\r\n    {\r\n      router.push(\"/login\")\r\n    }\r\n    let str = sessionStorage.getItem(\"user\") || \"{}\"\r\n    this.form = JSON.parse(str)\r\n  },\r\n  methods: {\r\n    update() {\r\n      request.put(\"/user/update\", this.form).then(res => {\r\n        console.log(res)\r\n        if (res.code === '0') {\r\n          ElMessage.success(\"更新成功\")\r\n          sessionStorage.setItem(\"user\", JSON.stringify(this.form))\r\n          // 触发Layout更新用户信息\r\n          this.$emit(\"userInfo\")\r\n        } else {\r\n          ElMessage.error(res.msg)\r\n        }\r\n      })\r\n\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style>\r\n.avatar-uploader  {\r\n  border: 1px dashed #d9d9d9;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n.avatar-uploader:hover {\r\n  border-color: #409EFF;\r\n}\r\n\r\n.avatar {\r\n  width: 178px;\r\n  height: 178px;\r\n  display: block;\r\n}\r\n.box-card {\r\n  width: 60%;\r\n  margin: auto;\r\n  padding: 20px;\r\n}\r\n</style>\r\n"],"mappings":";;;EAYsCA,KAAkB,EAAlB;IAAA;EAAA;;;;EACAA,KAAkB,EAAlB;IAAA;EAAA;;;EAgB3BA,KAA0B,EAA1B;IAAA;EAAA;AAA0B;;;;;;;;;uBA5BnCC,mBAAA,CAgCM,cA/BJC,YAAA,CA8BUC,kBAAA;IA9BDH,KAAwD,EAAxD;MAAA;MAAA;MAAA;IAAA;EAAwD;sBAC7D,MAAmC,C,4BAAnCI,mBAAA,CAAmC;MAA/BJ,KAAqB,EAArB;QAAA;MAAA;IAAqB,GAAC,MAAI,qBAChCE,YAAA,CAwBUG,kBAAA;MAxBAC,KAAK,EAAEC,KAAA,CAAAC,IAAI;MAAEC,GAAG,EAAC,MAAM;MAAC,aAAW,EAAC;;wBAC5C,MAEe,CAFfP,YAAA,CAEeQ,uBAAA;QAFDC,KAAK,EAAC;MAAK;0BACvB,MAAyE,CAAzET,YAAA,CAAyEU,mBAAA;UAA/DZ,KAAkB,EAAlB;YAAA;UAAA,CAAkB;sBAAUO,KAAA,CAAAC,IAAI,CAACK,QAAQ;qEAAbN,KAAA,CAAAC,IAAI,CAACK,QAAQ,GAAAC,MAAA;UAAEC,QAAQ,EAAR;;;UAEvDb,YAAA,CAEeQ,uBAAA;QAFDC,KAAK,EAAC;MAAI;0BACtB,MAAgE,CAAhET,YAAA,CAAgEU,mBAAA;UAAtDZ,KAAkB,EAAlB;YAAA;UAAA,CAAkB;sBAAUO,KAAA,CAAAC,IAAI,CAACQ,QAAQ;qEAAbT,KAAA,CAAAC,IAAI,CAACQ,QAAQ,GAAAF,MAAA;;;UAErDZ,YAAA,CAGeQ,uBAAA;QAHDC,KAAK,EAAC;MAAI;0BACpB,MAAuD,CAA3CJ,KAAA,CAAAC,IAAI,CAACS,IAAI,S,cAArBhB,mBAAA,CAAuD,QAAvDiB,UAAuD,EAAV,KAAG,K,mCACpCX,KAAA,CAAAC,IAAI,CAACS,IAAI,S,cAArBhB,mBAAA,CAAsD,QAAtDkB,UAAsD,EAAT,IAAE,K;;UAEnDjB,YAAA,CAGeQ,uBAAA;QAHDC,KAAK,EAAC;MAAM;0BACxB,MAA6D,CAA7DT,YAAA,CAA6DU,mBAAA